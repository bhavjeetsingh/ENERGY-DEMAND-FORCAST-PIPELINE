# MLflow Configuration
MLFLOW_TRACKING_URI=file:///app/mlruns
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db

# Azure Configuration (for cloud deployment)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=energy-forecast-rg
AZURE_APP_SERVICE_NAME=energyforecast-api-prod
AZURE_ACR_LOGIN_SERVER=energyforecastacr.azurecr.io
AZURE_ACR_USERNAME=your-acr-username
AZURE_ACR_PASSWORD=your-acr-password

# FastAPI Configuration
API_PORT=8000
API_HOST=0.0.0.0
DEBUG_MODE=false

# Python Configuration
PYTHONUNBUFFERED=1

# Model Configuration
MODEL_NAME=energy-demand-forecaster
MODEL_STAGE=latest
